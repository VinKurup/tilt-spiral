# copy to .env and fill in. .env is gitignored, so your key never gets committed.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# match routing (regional cluster): americas | asia | europe
RIOT_REGION=americas
# ladder + summoner routing (platform): na1, euw1, kr, ...
RIOT_PLATFORM=na1

# crawl tuning (optional; these are the defaults)
# RIOT_QUEUE=420                  # ranked solo/duo
# RIOT_RPS=15                     # request/sec cap (429s are still honored on top)
# CRAWL_TARGET_MATCHES=20000
# CRAWL_MATCHES_PER_PLAYER=20
